# Base URL of the AD Pictures content API.
# When unset, the site serves built-in placeholder media so the UI is fully
# previewable offline. Set this to flip the service detail pages to live data.
# Example: https://api.adpictures.example
NEXT_PUBLIC_API_BASE_URL=

# Base URL where portfolio images are served. The portfolio API returns each
# image as a storage key (e.g. "portfolio/<uuid>.jpg"); the site joins it to
# this base to build the image URL. When unset, portfolio cards fall back to
# their cinematic tone background. Example: https://cdn.adpictures.example
NEXT_PUBLIC_MEDIA_BASE_URL=

# Production domain of the website (no trailing slash). REQUIRED for correct SEO:
# canonical URLs, sitemap, OpenGraph/Twitter image links and JSON-LD all derive
# from it. Example: https://www.adpictures.et
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (the content of the meta tag Google
# gives you). Optional — leave blank until you verify the property.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
